{
  "name": "image-prompt-obsidian",
  "version": "0.2.0",
  "description": "원고를 FlowGenie용 이미지 프롬프트 JSON/TXT로 변환하는 Obsidian 플러그인 + 파생 스타터",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "package": "node esbuild.config.mjs production && node scripts/pack.mjs"
  },
  "keywords": ["obsidian-plugin", "ollama", "image-prompt", "flowgenie"],
  "author": "leedonwoo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  }
}
